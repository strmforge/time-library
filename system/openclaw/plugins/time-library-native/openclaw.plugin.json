{
  "id": "time-library-native",
  "name": "Time Library Native",
  "description": "Routes OpenClaw native webchat turns through memcore-cloud Zhiyi before provider dispatch.",
  "version": "0.1.0",
  "activation": {
    "onStartup": true,
    "onConfigPaths": [
      "plugins.entries.time-library-native"
    ]
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": {
        "type": "boolean",
        "default": false
      },
      "endpointUrl": {
        "type": "string"
      },
      "authToken": {
        "type": "string"
      },
      "dialogEntryToken": {
        "type": "string"
      },
      "timeoutMs": {
        "type": "integer",
        "minimum": 500,
        "maximum": 300000
      },
      "allowedChannels": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "enableModelCall": {
        "type": "boolean",
        "default": false
      },
      "forceZhiyiDirect": {
        "type": "boolean",
        "default": false
      }
    }
  }
}
