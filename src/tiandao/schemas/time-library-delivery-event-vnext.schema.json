{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/strmforge/time-library/schemas/time-library-delivery-event-vnext.schema.json",
  "title": "TimeLibraryDeliveryEventCandidate",
  "description": "Two-dimensional audience x form delivery candidate with separate proof stages.",
  "type": "object",
  "required": [
    "delivery_event_id",
    "retrieval_id",
    "platform",
    "delivery_audience",
    "delivery_form",
    "delivery_stage",
    "observed_at",
    "recorded_at"
  ],
  "properties": {
    "contract": {"const": "time_library.delivery_event_candidate.v2026.7.13"},
    "delivery_event_id": {"type": "string", "minLength": 1},
    "retrieval_id": {"type": "string", "minLength": 1},
    "platform": {"type": "string", "minLength": 1},
    "delivery_audience": {"enum": ["agent", "user"]},
    "delivery_form": {"enum": ["silent", "catalog", "context", "digest", "direct_answer"]},
    "delivery_stage": {"enum": ["stored", "retrieved", "selected", "delivered", "used", "helped", "unknown"]},
    "observed_at": {"type": "string", "format": "date-time"},
    "recorded_at": {"type": "string", "format": "date-time"},
    "delivery_observation": {"type": "object", "minProperties": 1},
    "used_source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["source_system"],
        "anyOf": [
          {"required": ["source_path"]},
          {"required": ["artifact_id"]},
          {"required": ["library_id"]},
          {"required": ["evidence_ref"]}
        ]
      }
    },
    "help_evidence": {"type": "object", "minProperties": 1},
    "unknown_reason": {"type": "string"}
  },
  "allOf": [
    {
      "if": {"properties": {"delivery_stage": {"enum": ["delivered", "used", "helped"]}}},
      "then": {"required": ["delivery_observation"]}
    },
    {
      "if": {"properties": {"delivery_stage": {"enum": ["used", "helped"]}}},
      "then": {"required": ["used_source_refs"]}
    },
    {
      "if": {"properties": {"delivery_stage": {"const": "helped"}}},
      "then": {"required": ["help_evidence"]}
    },
    {
      "if": {"properties": {"delivery_stage": {"const": "unknown"}}},
      "then": {"required": ["unknown_reason"]}
    }
  ],
  "additionalProperties": true
}
