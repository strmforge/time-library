{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/strmforge/time-library/schemas/time-library-memory-atom-vnext.schema.json",
  "title": "TimeLibraryMemoryAtomCandidate",
  "description": "R0 candidate only. Raw/source refs remain final evidence authority.",
  "type": "object",
  "required": [
    "atom_id",
    "revision_id",
    "shelf",
    "semantic_type",
    "state_role",
    "content",
    "observed_at",
    "recorded_at",
    "valid_from",
    "valid_to",
    "taint",
    "source_refs",
    "source_span",
    "verifier"
  ],
  "properties": {
    "contract": {"const": "time_library.memory_atom_candidate.v2026.7.13"},
    "atom_id": {"type": "string", "minLength": 1},
    "revision_id": {"type": "string", "minLength": 1},
    "shelf": {"enum": ["raw", "zhiyi", "xingce", "toolbook", "errata"]},
    "semantic_type": {"enum": ["claim", "event", "procedure", "preference"]},
    "state_role": {"enum": ["candidate", "active", "superseded", "transition", "conflicting", "unknown", "rejected"]},
    "content": {"type": "string", "minLength": 1},
    "subject": {"type": "string"},
    "predicate": {"type": "string"},
    "object": {},
    "observed_at": {"type": "string", "format": "date-time"},
    "recorded_at": {"type": "string", "format": "date-time"},
    "valid_from": {"type": "string", "format": "date-time"},
    "valid_to": {"type": ["string", "null"], "format": "date-time"},
    "supersedes": {"type": "array", "items": {"type": "string"}},
    "superseded_by": {"type": "array", "items": {"type": "string"}},
    "conflict_group": {"type": ["string", "null"]},
    "taint": {"enum": ["trusted", "untrusted_content", "instruction_like", "unknown"]},
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["source_system"],
        "anyOf": [
          {"required": ["source_path"]},
          {"required": ["artifact_id"]},
          {"required": ["library_id"]},
          {"required": ["evidence_ref"]}
        ],
        "additionalProperties": true
      }
    },
    "source_span": {"type": "object", "minProperties": 1},
    "verifier": {
      "type": "object",
      "required": ["coverage", "preservation", "faithfulness"],
      "properties": {
        "coverage": {"enum": ["pass", "fail", "unknown", "not_measured"]},
        "preservation": {"enum": ["pass", "fail", "unknown", "not_measured"]},
        "faithfulness": {"enum": ["pass", "fail", "unknown", "not_measured"]}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
