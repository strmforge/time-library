{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/strmforge/time-library/schemas/time-library-memory-transition-vnext.schema.json",
  "title": "TimeLibraryMemoryTransitionCandidate",
  "description": "Append-only derived transition candidate; it never changes raw.",
  "type": "object",
  "required": [
    "transition_id",
    "atom_id",
    "from_revision_ids",
    "to_revision_id",
    "transition_kind",
    "observed_at",
    "recorded_at",
    "source_refs",
    "verifier",
    "activation_allowed"
  ],
  "properties": {
    "contract": {"const": "time_library.memory_transition_candidate.v2026.7.13"},
    "transition_id": {"type": "string", "minLength": 1},
    "atom_id": {"type": "string", "minLength": 1},
    "from_revision_ids": {"type": "array", "items": {"type": "string"}},
    "to_revision_id": {"type": "string", "minLength": 1},
    "transition_kind": {"enum": ["activate", "supersede", "conflict", "reject", "mark_unknown"]},
    "observed_at": {"type": "string", "format": "date-time"},
    "recorded_at": {"type": "string", "format": "date-time"},
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["source_system"],
        "anyOf": [
          {"required": ["source_path"]},
          {"required": ["artifact_id"]},
          {"required": ["library_id"]},
          {"required": ["evidence_ref"]}
        ]
      }
    },
    "verifier": {
      "type": "object",
      "required": ["coverage", "preservation", "faithfulness"],
      "properties": {
        "coverage": {"enum": ["pass", "fail", "unknown", "not_measured"]},
        "preservation": {"enum": ["pass", "fail", "unknown", "not_measured"]},
        "faithfulness": {"enum": ["pass", "fail", "unknown", "not_measured"]}
      }
    },
    "activation_allowed": {"type": "boolean"},
    "authorization_ref": {"type": "string"}
  },
  "allOf": [
    {
      "if": {"properties": {"activation_allowed": {"const": true}}},
      "then": {
        "required": ["authorization_ref"],
        "properties": {
          "verifier": {
            "properties": {
              "coverage": {"const": "pass"},
              "preservation": {"const": "pass"},
              "faithfulness": {"const": "pass"}
            }
          }
        }
      }
    }
  ],
  "additionalProperties": true
}
