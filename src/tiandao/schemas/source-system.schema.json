{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://honghuang.ai/schemas/tiandao/source-system.schema.json",
  "title": "SourceSystem",
  "description": "源系统 - 记忆与数据的来源平台",
  "type": "object",
  "required": ["systemId", "type", "platform"],
  "properties": {
    "systemId": {
      "type": "string",
      "description": "系统唯一标识"
    },
    "name": {
      "type": "string",
      "description": "显示名称"
    },
    "type": {
      "type": "string",
      "enum": [
        "openclaw",
        "hermes",
        "codex",
        "local_files",
        "yifanchen",
        "custom"
      ],
      "description": "系统类型"
    },
    "platform": {
      "type": "string",
      "enum": ["windows", "linux", "darwin", "wsl"],
      "description": "运行平台"
    },
    "status": {
      "type": "string",
      "enum": ["active", "shadow", "limited", "inactive"],
      "description": "状态"
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "支持的能力列表"
    },
    "endpoint": {
      "type": "object",
      "description": "连接端点",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["websocket", "http", "cli", "ssh"]
        },
        "url": {
          "type": "string"
        },
        "port": {
          "type": "number"
        }
      }
    },
    "models": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "可用模型列表"
    },
    "lastSeen": {
      "type": "string",
      "format": "date-time"
    }
  }
}
